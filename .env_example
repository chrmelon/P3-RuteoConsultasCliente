# =============================================================================
# Variables de entorno - Sistema Multi-Agente Henry
# =============================================================================
# Copia este archivo como .env y rellena tus valores reales:
#   cp .env_example .env
#
# NUNCA subas el archivo .env a git. Ya esta en el .gitignore.
# =============================================================================

# --- OpenAI (obligatorio) ---
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- LangSmith (opcional) - para tracing y observabilidad ---
# Crea una cuenta gratis en: https://smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=henry-multi-agent


